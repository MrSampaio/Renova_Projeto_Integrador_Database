CREATE DATABASE IF NOT EXISTS renova;

USE renova;

CREATE TABLE usuario (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    telefone CHAR(11),
    email VARCHAR(100) UNIQUE,
    senha VARCHAR(255) NOT NULL,
    tipo_usuario ENUM('CLIENTE', 'FUNCIONARIO') DEFAULT 'CLIENTE' NOT NULL
);

CREATE TABLE produto (
    id_produto INT AUTO_INCREMENT PRIMARY KEY,
    nome_produto VARCHAR(100) NOT NULL,
    descricao VARCHAR(150) NOT NULL,
    preco DECIMAL(10, 2) NOT NULL,
    status ENUM('Disponível', 'Reservado', 'Vendido') DEFAULT 'Disponível'
);

CREATE TABLE reserva (
    id_reserva INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,
    total_reserva DECIMAL(10, 2) NOT NULL,
    metodo_pagamento ENUM('Dinheiro', 'Débito', 'Pix') DEFAULT 'Débito',
    data_reserva DATETIME DEFAULT CURRENT_TIMESTAMP,
    data_validade DATE,
    status_reserva ENUM('Aguardando pagamento', 'Concluída', 'jus') DEFAULT 'Aguardando pagamento',
    FOREIGN KEY (id_usuario) REFERENCES USUARIO(id_usuario)
);

SELECT * FROM reserva;


CREATE TABLE itens_reserva(
    id_reserva INT NOT NULL,
    id_produto INT NOT NULL UNIQUE,
    PRIMARY KEY (id_reserva, id_produto),
    FOREIGN KEY (id_reserva) REFERENCES reserva(id_reserva),
    FOREIGN KEY (id_produto) REFERENCES produto(id_produto)
);
SELECT * FROM itens_reserva;

DELIMITER //

CREATE PROCEDURE PROC_LOGIN_USUARIO(
    IN p_email VARCHAR(100),
    IN p_senha VARCHAR(255)
)
BEGIN
    SELECT
        id_usuario,
        nome,
        tipo_usuario
    FROM
        usuario
    WHERE
        email = p_email
        AND senha = p_senha;
END; //

DELIMITER;

DELIMITER //

CREATE PROCEDURE PROC_CADASTRAR_USUARIO(
    IN p_nome VARCHAR(100),
    IN p_telefone VARCHAR(20),
    IN p_email VARCHAR(100),
    IN p_senha VARCHAR(255),
    IN p_tipo_usuario VARCHAR(100)
)
BEGIN
    INSERT INTO usuario (nome, telefone, email, senha, tipo_usuario)
    VALUES (p_nome, p_telefone, p_email, p_senha, p_tipo_usuario);

END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE PROC_CADASTRAR_PRODUTO(
    IN p_nome_produto VARCHAR(100),
    IN p_descricao VARCHAR(150),
    IN p_preco DECIMAL(10, 2),
    IN p_status VARCHAR(20)
)
BEGIN
    INSERT INTO produto(nome_produto, descricao, preco, status)
    VALUES (p_nome_produto, p_descricao, p_preco, p_status);

END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE PROC_LISTAR_PRODUTOS()
BEGIN
    SELECT
        id_produto,
        nome_produto,
        descricao,
        preco,
        status
    FROM
        produto;
END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE PROC_BUSCAR_PRODUTO_POR_ID(
    IN p_id_produto INT
)
BEGIN
    SELECT
        id_produto,
        nome_produto,
        descricao,
        preco,
        status
    FROM
        produto
    WHERE
        id_produto = p_id_produto;
END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE PROC_BUSCAR_PRODUTO_POR_NOME(
    IN p_nome VARCHAR(100)
)
BEGIN
    SELECT
        id_produto,
        nome_produto,
        descricao,
        preco,
        status
    FROM
        produto
    WHERE
        nome_produto LIKE CONCAT('%', p_nome, '%');
END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE PROC_CRIAR_RESERVA(
    IN p_id_usuario INT,
    IN p_total DECIMAL(10, 2),
    IN p_metodo VARCHAR(50),
    OUT p_id_gerado INT
)
BEGIN
    INSERT INTO reserva (id_usuario, total_reserva, metodo_pagamento, data_validade)
    VALUES (p_id_usuario, p_total, p_metodo, DATE_ADD(CURRENT_DATE(), INTERVAL 7 DAY));

    SET p_id_gerado = LAST_INSERT_ID();
END //

DELIMITER ;


DELIMITER //


CREATE PROCEDURE PROC_INSERIR_ITEM_RESERVA(
    IN p_id_reserva INT,
    IN p_id_produto INT
)
BEGIN

    INSERT INTO itens_reserva (id_reserva, id_produto)
    VALUES (p_id_reserva, p_id_produto);

    UPDATE produto
    SET status = 'Reservado'
    WHERE id_produto = p_id_produto;
END //

DELIMITER ;

